# NextAuth — generate secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=https://your-app.vercel.app

# Single hardcoded user credentials
APP_USER_EMAIL=you@example.com
APP_USER_PASSWORD=your-secure-password

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Resend (email)
RESEND_API_KEY=re_...

# Email address for monthly reports
REPORT_EMAIL=you@example.com

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Vercel Cron secret (any random string)
CRON_SECRET=your-cron-secret

# Email domain for "from:" addresses
EMAIL_DOMAIN=kollen.vercel.app
